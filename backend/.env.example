# DesignCraft 后端环境变量示例
# 请根据实际七牛云账号与服务配置填写

APP_NAME=DesignCraft Agent Backend
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# 七牛 Kodo 对象存储
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET_NAME=design-craft
QINIU_BUCKET_DOMAIN=tccc78x9r.hd-bkt.clouddn.com
QINIU_BUCKET_SCHEME=http
QINIU_UPLOAD_HOST=up.qiniup.com

# 七牛 MaaS
QINIU_MAAS_API_KEY=
QINIU_MAAS_BASE_URL=https://api.qnaigc.com/v1
QINIU_CHAT_MODEL=deepseek-v3
QINIU_IMAGE_MODEL=kling-v2-1

# 搜索能力
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_GOOGLE_DOMAIN=google.com
SERPAPI_GL=cn
SERPAPI_HL=zh-cn

# 任务与默认参数
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_IMAGE_COUNT=1
TASK_POLL_INTERVAL_SECONDS=2
TASK_POLL_TIMEOUT_SECONDS=120
PLANNER_MAX_TOKENS=1024
AGUI_DEFAULT_IMAGE_COUNT=1
AGUI_SEARCH_RESULT_LIMIT=5

# 设计技能目录
SKILL_BASE_DIR=backend/design-skills
